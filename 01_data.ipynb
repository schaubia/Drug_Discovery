 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 01 — Data Loading & Exploratory Analysis\n",
    "**EGFR Kinase | TDC Dataset**\n",
    "\n",
    "This notebook:\n",
    "1. Loads the EGFR inhibition dataset from TDC (~15k compounds)\n",
    "2. Validates and cleans SMILES strings with RDKit\n",
    "3. Explores the activity distribution and chemical space\n",
    "4. Creates train / validation / test splits used by all models\n",
    "5. Saves processed data to `./data/` for downstream notebooks\n",
    "\n",
    "> **Prerequisite:** `00_setup.ipynb` must have run successfully."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 0. Imports & Config"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Load project config\n",
    "with open('./config.json', 'r') as f:\n",
    "    CONFIG = json.load(f)\n",
    "\n",
    "SEED = CONFIG['random_seed']\n",
    "np.random.seed(SEED)\n",
    "\n",
    "print('Config loaded.')\n",
    "print(f'  Target:   {CONFIG[\"target\"]}')\n",
    "print(f'  Task:     {CONFIG[\"task\"]}')\n",
    "print(f'  Seed:     {SEED}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load EGFR Dataset from TDC"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from tdc.single_pred import HTS\n",
    "from tdc.utils import retrieve_label_name_list\n",
    "\n",
    "# EGFR inhibition dataset from TDC\n",
    "# Target: IC50 values (nM) — lower = more potent inhibitor\n",
    "print('Loading EGFR dataset from TDC...')\n",
    "\n",
    "data = HTS(name='EGFR_DrugBankFull')\n",
    "df_raw = data.get_data()\n",
    "\n",
    "print(f'  Raw dataset shape: {df_raw.shape}')\n",
    "print(f'  Columns: {list(df_raw.columns)}')\n",
    "print()\n",
    "df_raw.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Basic dataset overview\n",
    "print('Dataset Overview')\n",
    "print('='*45)\n",
    "print(f'  Total compounds:    {len(df_raw):,}')\n",
    "print(f'  Unique SMILES:      {df_raw[\"Drug\"].nunique():,}')\n",
    "print()\n",
    "print('Activity column (Y):')\n",
    "print(df_raw['Y'].describe())\n",
    "print()\n",
    "print('Missing values:')\n",
    "print(df_raw.isnull().sum())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. SMILES Validation & Cleaning with RDKit"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from rdkit import Chem\n",
    "from rdkit.Chem import Descriptors, AllChem, Lipinski\n",
    "from tqdm import tqdm\n",
    "\n",
    "def validate_and_featurize(smiles):\n",
    "    \"\"\"Validate SMILES and compute basic molecular descriptors.\"\"\"\n",
    "    try:\n",
    "        mol = Chem.MolFromSmiles(smiles)\n",
    "        if mol is None:\n",
    "            return None\n",
    "        return {\n",
    "            'mol_weight':    Descriptors.MolWt(mol),\n",
    "            'logp':          Descriptors.MolLogP(mol),\n",
    "            'hbd':           Lipinski.NumHDonors(mol),      # H-bond donors\n",
    "            'hba':           Lipinski.NumHAcceptors(mol),   # H-bond acceptors\n",
    "            'tpsa':          Descriptors.TPSA(mol),         # Topological polar SA\n",
    "            'rot_bonds':     Lipinski.NumRotatableBonds(mol),\n",
    "            'aromatic_rings': Descriptors.NumAromaticRings(mol),\n",
    "            'heavy_atoms':   mol.GetNumHeavyAtoms(),\n",
    "            'valid':         True\n",
    "        }\n",
    "    except:\n",
    "        return None\n",
    "\n",
    "print('Validating SMILES and computing descriptors...')\n",
    "descriptor_list = []\n",
    "valid_mask = []\n",
    "\n",
    "for smi in tqdm(df_raw['Drug'], desc='Processing'):\n",
    "    result = validate_and_featurize(smi)\n",
    "    if result is not None:\n",
    "        descriptor_list.append(result)\n",
    "        valid_mask.append(True)\n",
    "    else:\n",
    "        descriptor_list.append({})\n",
    "        valid_mask.append(False)\n",
    "\n",
    "df_raw['valid_smiles'] = valid_mask\n",
    "n_invalid = (~df_raw['valid_smiles']).sum()\n",
    "print(f'\\n  Invalid SMILES removed: {n_invalid}')\n",
    "\n",
    "# Keep only valid molecules\n",
    "df_desc = pd.DataFrame(descriptor_list)\n",
    "df_clean = pd.concat([df_raw.reset_index(drop=True), df_desc], axis=1)\n",
    "df_clean = df_clean[df_clean['valid_smiles']].drop(columns=['valid_smiles'])\n",
    "df_clean = df_clean.dropna(subset=['Y'])\n",
    "\n",
    "print(f'  Clean dataset: {len(df_clean):,} compounds')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Activity Distribution & Lipinski Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(2, 3, figsize=(16, 10))\n",
    "fig.suptitle('EGFR Dataset — Exploratory Analysis', fontsize=14, fontweight='bold')\n",
    "\n",
    "# ── Activity Distribution (IC50) ─────────────────────────────────\n",
    "ax = axes[0, 0]\n",
    "ax.hist(df_clean['Y'], bins=50, color='steelblue', edgecolor='white', alpha=0.8)\n",
    "ax.set_xlabel('IC50 Activity (Y)')\n",
    "ax.set_ylabel('Count')\n",
    "ax.set_title('Activity Distribution')\n",
    "\n",
    "# ── Log-transformed IC50 ─────────────────────────────────────────\n",
    "ax = axes[0, 1]\n",
    "log_y = np.log1p(df_clean['Y'])\n",
    "ax.hist(log_y, bins=50, color='coral', edgecolor='white', alpha=0.8)\n",
    "ax.set_xlabel('log(IC50 + 1)')\n",
    "ax.set_title('Log Activity (used for training)')\n",
    "\n",
    "# ── Molecular Weight ────────────────────────────────────────────\n",
    "ax = axes[0, 2]\n",
    "ax.hist(df_clean['mol_weight'], bins=50, color='mediumseagreen', edgecolor='white', alpha=0.8)\n",
    "ax.axvline(x=500, color='red', linestyle='--', label='Lipinski MW ≤ 500')\n",
    "ax.set_xlabel('Molecular Weight (Da)')\n",
    "ax.set_title('Molecular Weight')\n",
    "ax.legend()\n",
    "\n",
    "# ── LogP Distribution ───────────────────────────────────────────\n",
    "ax = axes[1, 0]\n",
    "ax.hist(df_clean['logp'], bins=50, color='mediumpurple', edgecolor='white', alpha=0.8)\n",
    "ax.axvline(x=5, color='red', linestyle='--', label='Lipinski LogP ≤ 5')\n",
    "ax.set_xlabel('LogP (lipophilicity)')\n",
    "ax.set_title('LogP Distribution')\n",
    "ax.legend()\n",
    "\n",
    "# ── Lipinski Rule-of-5 Compliance ────────────────────────────────\n",
    "ax = axes[1, 1]\n",
    "lipinski_pass = (\n",
    "    (df_clean['mol_weight'] <= 500) &\n",
    "    (df_clean['logp'] <= 5) &\n",
    "    (df_clean['hbd'] <= 5) &\n",
    "    (df_clean['hba'] <= 10)\n",
    ")\n",
    "counts = lipinski_pass.value_counts()\n",
    "ax.pie([counts.get(True, 0), counts.get(False, 0)],\n",
    "       labels=['Passes Ro5', 'Fails Ro5'],\n",
    "       colors=['mediumseagreen', 'salmon'],\n",
    "       autopct='%1.1f%%', startangle=90)\n",
    "ax.set_title(\"Lipinski Rule-of-5\")\n",
    "\n",
    "# ── TPSA vs LogP ────────────────────────────────────────────────\n",
    "ax = axes[1, 2]\n",
    "scatter = ax.scatter(df_clean['logp'], df_clean['tpsa'],\n",
    "                     c=np.log1p(df_clean['Y']),\n",
    "                     cmap='RdYlGn_r', alpha=0.4, s=8)\n",
    "plt.colorbar(scatter, ax=ax, label='log(IC50)')\n",
    "ax.set_xlabel('LogP')\n",
    "ax.set_ylabel('TPSA')\n",
    "ax.set_title('LogP vs TPSA (colored by activity)')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('./results/01_eda.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Plot saved to results/01_eda.png')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Known EGFR drugs — validation anchors\n",
    "# If our models rank these well, the pipeline is working\n",
    "known_egfr_drugs = {\n",
    "    'Gefitinib':   'COc1cc2ncnc(Nc3ccc(F)c(Cl)c3)c2cc1OCCCN1CCOCC1',\n",
    "    'Erlotinib':   'C#Cc1cccc(Nc2ncnc3cc(OCCOC)c(OCCOC)cc23)c1',\n",
    "    'Osimertinib': 'C=CC(=O)Nc1cc2c(Nc3ccc(F)c(Cl)c3)ncnc2cc1NC(=O)c1ccc(N(C)CCN(C)C)cc1',\n",
    "    'Afatinib':    'CN(C)C/C=C/C(=O)Nc1cc2c(Nc3ccc(F)c(Cl)c3)ncnc2cc1OCC1=CN(C)C=C1',\n",
    "}\n",
    "\n",
    "print('Known EGFR Inhibitors — Validation Anchors')\n",
    "print('='*55)\n",
    "from rdkit import Chem\n",
    "from rdkit.Chem import Descriptors\n",
    "\n",
    "for name, smi in known_egfr_drugs.items():\n",
    "    mol = Chem.MolFromSmiles(smi)\n",
    "    if mol:\n",
    "        mw = Descriptors.MolWt(mol)\n",
    "        logp = Descriptors.MolLogP(mol)\n",
    "        present = any(df_clean['Drug'] == smi)\n",
    "        print(f'  {name:<15} MW={mw:.0f}  LogP={logp:.1f}  In dataset: {\"✓\" if present else \"—\"}')\n",
    "\n",
    "print()\n",
    "print('These will be used to validate model predictions in 03_score.ipynb')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Log-Transform Activity\n",
    "IC50 values span several orders of magnitude — log transform is standard in QSAR."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "\n",
    "# Log transform: reduces skew, makes regression more stable\n",
    "df_clean['Y_log'] = np.log1p(df_clean['Y'])\n",
    "\n",
    "print('Activity transformation:')\n",
    "print(f'  Original  mean={df_clean[\"Y\"].mean():.1f}  std={df_clean[\"Y\"].std():.1f}  skew={df_clean[\"Y\"].skew():.2f}')\n",
    "print(f'  Log+1     mean={df_clean[\"Y_log\"].mean():.2f}  std={df_clean[\"Y_log\"].std():.2f}  skew={df_clean[\"Y_log\"].skew():.2f}')\n",
    "print()\n",
    "print('Log transform reduces skewness — better for regression models.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Train / Validation / Test Split"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "TEST_SIZE = CONFIG['test_size']   # 0.2\n",
    "VAL_SIZE  = CONFIG['val_size']    # 0.1 of remaining\n",
    "\n",
    "# First: separate test set (held out completely until 04_benchmark)\n",
    "df_trainval, df_test = train_test_split(\n",
    "    df_clean, test_size=TEST_SIZE,\n",
    "    random_state=SEED, shuffle=True\n",
    ")\n",
    "\n",
    "# Then: split remaining into train and validation\n",
    "val_fraction = VAL_SIZE / (1 - TEST_SIZE)\n",
    "df_train, df_val = train_test_split(\n",
    "    df_trainval, test_size=val_fraction,\n",
    "    random_state=SEED, shuffle=True\n",
    ")\n",
    "\n",
    "print('Data splits:')\n",
    "print(f'  Train:      {len(df_train):>6,} compounds  ({len(df_train)/len(df_clean)*100:.0f}%)')\n",
    "print(f'  Validation: {len(df_val):>6,} compounds  ({len(df_val)/len(df_clean)*100:.0f}%)')\n",
    "print(f'  Test:       {len(df_test):>6,} compounds  ({len(df_test)/len(df_clean)*100:.0f}%)')\n",
    "print(f'  Total:      {len(df_clean):>6,} compounds')\n",
    "print()\n",
    "\n",
    "# Verify activity distribution is similar across splits\n",
    "print('Activity mean (Y_log) per split — should be similar:')\n",
    "print(f'  Train:      {df_train[\"Y_log\"].mean():.3f}')\n",
    "print(f'  Validation: {df_val[\"Y_log\"].mean():.3f}')\n",
    "print(f'  Test:       {df_test[\"Y_log\"].mean():.3f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Save Processed Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "\n",
    "os.makedirs('./data', exist_ok=True)\n",
    "\n",
    "# Save splits\n",
    "df_train.to_csv('./data/train.csv', index=False)\n",
    "df_val.to_csv('./data/val.csv', index=False)\n",
    "df_test.to_csv('./data/test.csv', index=False)\n",
    "df_clean.to_csv('./data/full_clean.csv', index=False)\n",
    "\n",
    "# Save known drug anchors for validation\n",
    "import json\n",
    "with open('./data/known_drugs.json', 'w') as f:\n",
    "    json.dump(known_egfr_drugs, f, indent=2)\n",
    "\n",
    "print('Saved:')\n",
    "print('  data/train.csv         —', len(df_train), 'rows')\n",
    "print('  data/val.csv           —', len(df_val), 'rows')\n",
    "print('  data/test.csv          —', len(df_test), 'rows')\n",
    "print('  data/full_clean.csv    —', len(df_clean), 'rows')\n",
    "print('  data/known_drugs.json  — 4 EGFR inhibitor anchors')\n",
    "print()\n",
    "print('✓ Data pipeline complete — ready for 02_baselines.ipynb')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
